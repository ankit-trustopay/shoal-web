// Shoal AI — database schema (PostgreSQL via Prisma)

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SwarmStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id              String   @id @default(cuid())
  clerkId         String   @unique
  email           String   @unique
  dailyCredits    Int      @default(150)
  vaultCredits    Int      @default(0)
  plan            String   @default("FREE")
  lastResetDate   DateTime @default(now()) @map("lastDailyReset")
  swarms          Swarm[]
}

/// Debate sessions (exposed as "Debate" in /api/debates).
model Swarm {
  id           String      @id @default(cuid())
  userId       String
  premise      String
  status       SwarmStatus @default(PENDING)
  agentCount   Int
  resultData   Json?
  confidence   Int?
  votesFor     Int?
  votesAgainst Int?
  votesNeutral Int?
  runtime       Int?
  cost          Float?
  agentProfiles     Json?
  debateTranscript  Json?
  /// Executive report: 3 bullet TL;DR strings
  tldr              Json?
  /// Agent friction cards: [{ name, stance, argument }]
  frictionMatrix    Json?
  /// Pre-mortem: { failureModes, criticalUnknowns }
  preMortem         Json?
  /// Roadmap: { immediateAction, planB }
  executionRoadmap  Json?
  /// Hero: { recommendation, fitForYou, oneLineReason }
  executiveSummary  Json?
  /// Tension board + findings: { bullCase, bearCase, shoalRecommendation, mainOpportunity, mainRisk, hiddenTradeoff, bestAlternative, explanation }
  boardroomSummary  Json?
  /// Debate room cards: [{ role, conclusion, disagreement, mindChanged }]
  debateRoom        Json?
  /// Research map: { stats: { totalSources, highSignal, contradictory, dominantConsensus }, clusters: { reddit, youtube, official, news } }
  evidenceVault     Json?
  createdAt         DateTime    @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  evidence  Evidence[]

  @@index([userId])
  @@index([status])
}

model Evidence {
  id      String @id @default(cuid())
  swarmId String
  title   String
  source  String
  url     String
  snippet String

  swarm Swarm @relation(fields: [swarmId], references: [id], onDelete: Cascade)

  @@index([swarmId])
}

model Message {
  id        String   @id @default(cuid())
  swarmId   String
  text      String
  role      String
  createdAt DateTime @default(now())

  swarm Swarm @relation(fields: [swarmId], references: [id], onDelete: Cascade)

  @@index([swarmId])
}
