// Shoal AI — database schema (PostgreSQL via Prisma)

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SwarmStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id      String  @id @default(cuid())
  email   String  @unique
  credits Int     @default(0)
  swarms  Swarm[]
}

model Swarm {
  id           String      @id @default(cuid())
  userId       String
  premise      String
  status       SwarmStatus @default(PENDING)
  agentCount   Int
  resultData   Json?
  confidence   Int?
  votesFor     Int?
  votesAgainst Int?
  votesNeutral Int?
  runtime      Int?
  cost         Float?
  createdAt    DateTime    @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  evidence  Evidence[]

  @@index([userId])
  @@index([status])
}

model Evidence {
  id      String @id @default(cuid())
  swarmId String
  title   String
  source  String
  url     String
  snippet String

  swarm Swarm @relation(fields: [swarmId], references: [id], onDelete: Cascade)

  @@index([swarmId])
}

model Message {
  id        String   @id @default(cuid())
  swarmId   String
  text      String
  role      String
  createdAt DateTime @default(now())

  swarm Swarm @relation(fields: [swarmId], references: [id], onDelete: Cascade)

  @@index([swarmId])
}
