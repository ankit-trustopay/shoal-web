# Vercel Postgres (or any PostgreSQL provider)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# MiroFish Python engine (separate server)
MIROFISH_ENGINE_URL="http://localhost:8000"
MIROFISH_ENGINE_API_KEY=""

# Webhook auth (required in production)
ENGINE_WEBHOOK_SECRET="change-me-in-production"

# CORS: shoal-ui origin(s), comma-separated for dev + production
FRONTEND_ORIGIN="https://shoal-ui-woad.vercel.app,http://localhost:5173"
